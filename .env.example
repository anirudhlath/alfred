# Alfred Environment Configuration
# Copy to .env and fill in values.

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT (Mosquitto)
MQTT_HOST=localhost
MQTT_PORT=1883

# Ollama (local SLM inference)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# LM Studio (OpenAI-compatible local inference alternative)
LMSTUDIO_HOST=http://localhost:1234

# Home Assistant
HA_HOST=http://localhost:8123
HA_TOKEN=

# Research vault
RESEARCH_VAULT_PATH=./research

# Telemetry (SigNoz/OpenTelemetry)
SIGNOZ_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Phase 3: Conscious Engine (Claude / System 2)
# API key for Anthropic Claude — required for Phase 3 features
CLAUDE_API_KEY=
# Claude model to use for System 2 reasoning
CLAUDE_MODEL=claude-opus-4-6
# Idle session timeout before conversation context is cleared (minutes)
SESSION_TIMEOUT_MINUTES=30
# Proactivity level: opinionated | moderate | conservative
PROACTIVITY_LEVEL=opinionated

# Phase 3: Cost guardrails
# Maximum daily spend on cloud LLM APIs in USD
DAILY_COST_CAP_USD=5.0

# Phase 3: Episodic memory
# Days to keep episodic memories in the hot (full-detail) store
EPISODIC_HOT_DAYS=7
# Days after which episodic memories are compressed/summarised
EPISODIC_COMPRESS_DAYS=90

# Phase 3: Voice
# Minimum ASR confidence score required to act on a voice utterance (0–1)
VOICE_CONFIDENCE_THRESHOLD=0.85
# TTS backend selection (kokoro | piper). Kokoro-82M is the default neural voice.
ALFRED_TTS_BACKEND=kokoro
# Kokoro voice id (catalogue in docs/voice.md)
KOKORO_VOICE=am_michael
# Kokoro speech rate (1.0 = natural)
KOKORO_SPEED=1.0
# ONNX execution provider: auto | cpu | cuda | coreml (auto → CUDA on the 4090, else CPU)
KOKORO_ONNX_PROVIDER=auto

# Phase 3: Signal notifications
# Phone number (E.164 format, e.g. +15555550100) for Signal message delivery
SIGNAL_PHONE_NUMBER=

# APNs push notifications (optional — all three required to enable the adapter)
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
# Path to the .p8 signing key; defaults to secrets/AuthKey_<APNS_KEY_ID>.p8
APNS_KEY_PATH=

# Phase 3: Logging
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Emit logs as JSON (true) or human-readable text (false)
LOG_JSON=false

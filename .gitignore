# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
venv/

# Environment
.env

# IDE
.vscode/
.idea/

# Obsidian vault config (research data itself is tracked)
research/.obsidian/

# Superpowers brainstorm sessions
.superpowers/

# Runtime data & personal information (not source)
core/memory/scratchpad.md
core/memory/triggers/
*.db
*.db-*

# Personal memory files — only examples are tracked
core/memory/preferences/*
!core/memory/preferences/.example/
core/memory/profile/*
!core/memory/profile/.example/

# Claude Code local settings
.claude/settings.local.json
.claude/skills
.worktrees/

# Eval run artifacts (generated JSON)
evals/runs/
core/voice/models/

# Web frontend
web/node_modules/
web/dist/

# Secrets — APNs .p8 signing key and other local credentials (never commit)
secrets/

# Local satellite fleet config — only the .example is tracked
config/satellites.yaml
